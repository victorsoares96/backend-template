APP_PORT=4000

TYPEORM_CONNECTION=mysql
TYPEORM_HOST=127.0.0.1
TYPEORM_USERNAME=postgres
TYPEORM_PASSWORD=postgres
TYPEORM_DATABASE=backend_template
TYPEORM_PORT=3306
TYPEORM_SYNCHRONIZE=false
TYPEORM_LOGGING=true
TYPEORM_ENTITIES=dist/modules/**/infra/typeorm/entities/*.entity.js
TYPEORM_MIGRATIONS=dist/shared/infra/typeorm/migrations/*.js
TYPEORM_ENTITIES_DIR=dist/modules/**/infra/typeorm/entities
TYPEORM_MIGRATIONS_DIR=dist/shared/infra/typeorm/migrations
